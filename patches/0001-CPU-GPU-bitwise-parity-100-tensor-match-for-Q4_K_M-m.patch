+// Compute one Q4_K thread's partial dot product for a single block
+static inline float q4k_partial(const block_q4_K * bq4, const block_q8_1 * bq8, int iqs) {
+    const int bq8_offset = 2 * ((iqs / 2) / 4);
+    const int pos = (iqs / 2) % 4;

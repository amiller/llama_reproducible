     GGML_ASSERT(eps >= 0.0f);
 
+    if (ggml_is_deterministic()) {
+        // GPU-matching RMSNorm: replicate norm.cu's thread stride + warp butterfly
+        const int block_size = (ne00 < 1024) ? 256 : 1024;
+        const int WARP_SIZE = 32;
+
+        for (int64_t i03 = 0; i03 < ne03; i03++) {
+            for (int64_t i02 = 0; i02 < ne02; i02++) {
+                for (int64_t i01 = ith; i01 < ne01; i01 += nth) {
+                    const float * x = (float *) ((char *) src0->data + i01*nb01 + i02*nb02 + i03*nb03);
+                    float * y = (float *) ((char *) dst->data + i01*nb1 + i02*nb2 + i03*nb3);
+
+                    // Phase 1: each "thread" accumulates its strided elements
+                    float partials[1024];
+                    for (int tid = 0; tid < block_size; tid++) {
+                        float tmp = 0.0f;
+                        for (int64_t col = tid; col < ne00; col += block_size)
+                            tmp += x[col] * x[col];
+                        partials[tid] = tmp;
+                    }
+
+                    // Phase 2+3: warp butterfly + inter-warp butterfly
+                    // Use double-buffered butterfly for correctness (simultaneous shfl_xor)
+                    // Warp-level: reduce each group of 32 to lane 0
+                    for (int w = 0; w < block_size; w += WARP_SIZE) {
+                        float buf[2][WARP_SIZE];
+                        memcpy(buf[0], &partials[w], WARP_SIZE * sizeof(float));
+                        int cur = 0;
+                        for (int offset = WARP_SIZE/2; offset > 0; offset >>= 1) {
+                            int nxt = 1 - cur;
+                            for (int lane = 0; lane < WARP_SIZE; lane++)
+                                buf[nxt][lane] = buf[cur][lane] + buf[cur][lane ^ offset];
+                            cur = nxt;
+                        }
+                        partials[w] = buf[cur][0]; // lane 0 result
+                    }
+
+                    float tmp;
+                    if (block_size <= WARP_SIZE) {
+                        tmp = partials[0];
+                    } else {
+                        // Inter-warp: collect lane 0 from each warp, butterfly again
+                        float s_sum[WARP_SIZE];
+                        int n_warps = block_size / WARP_SIZE;
+                        for (int i = 0; i < n_warps; i++) s_sum[i] = partials[i * WARP_SIZE];
+                        for (int i = n_warps; i < WARP_SIZE; i++) s_sum[i] = 0.0f;
+
+                        float buf2[2][WARP_SIZE];
+                        memcpy(buf2[0], s_sum, WARP_SIZE * sizeof(float));
+                        int cur = 0;
+                        for (int offset = WARP_SIZE/2; offset > 0; offset >>= 1) {
+                            int nxt = 1 - cur;
+                            for (int lane = 0; lane < WARP_SIZE; lane++)

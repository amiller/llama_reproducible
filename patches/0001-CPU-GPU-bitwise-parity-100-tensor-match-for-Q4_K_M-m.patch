diff --git a/tools/det-diag/det-diag.cpp b/tools/det-diag/det-diag.cpp
new file mode 100644
index 00000000..28297a98
--- /dev/null
+++ b/tools/det-diag/det-diag.cpp
@@ -0,0 +1,124 @@
+// Deterministic diagnostics: hash every tensor during inference
+// Run on GPU and CPU builds, diff output to find first diverging operation
+#include "arg.h"
+#include "common.h"
+#include "sampling.h"
+#include "llama.h"
+#include "ggml.h"
+#include "ggml-backend.h"
+#include <cstdio>
+#include <cstdint>
+#include <cstring>
+#include <vector>
+
+static uint32_t fnv1a(const void * data, size_t len) {
+    uint32_t h = 2166136261u;
+    const uint8_t * p = (const uint8_t *)data;
+    for (size_t i = 0; i < len; i++) {
+        h ^= p[i];
+        h *= 16777619u;
+    }
+    return h;
+}
+
+struct diag_state {
+    int token_idx;
+};
+
+static bool tensor_callback(struct ggml_tensor * t, bool ask, void * user_data) {
+    if (ask) return true;
+
+    auto * state = (diag_state *)user_data;
+    size_t nbytes = ggml_nbytes(t);
+    std::vector<uint8_t> buf(nbytes);
+    ggml_backend_tensor_get(t, buf.data(), 0, nbytes);
+
+    uint32_t hash = fnv1a(buf.data(), nbytes);
+
+    // first 2 floats for quick eyeball comparison
+    float f0 = 0, f1 = 0;
+    if (nbytes >= 4) memcpy(&f0, buf.data(), 4);
+    if (nbytes >= 8) memcpy(&f1, buf.data() + 4, 4);
+
+    printf("T%d %-40s [%5lld×%-5lld] %08x  %.8e %.8e\n",
+        state->token_idx, ggml_get_name(t),
+        (long long)t->ne[0], (long long)t->ne[1],
+        hash, f0, f1);
+
+    // For attention output, dump at token boundaries
+    const char *name = ggml_get_name(t);
+    if (name && strstr(name, "__fattn__") && state->token_idx == 0) {
+        printf("  DIMS [%lld,%lld,%lld,%lld]\n", (long long)t->ne[0], (long long)t->ne[1], (long long)t->ne[2], (long long)t->ne[3]);
+        // Dump first 4 floats at each token: offset = token * ne[0] * ne[1]
+        int stride = t->ne[0] * t->ne[1]; // 128*16 = 2048 per token
+        for (int tok = 0; tok < 4 && tok < t->ne[2]; tok++) {
+            int off = tok * stride;
+            printf("  TOK%d@%d", tok, off);
+            for (int i = 0; i < 4; i++) {
+                uint32_t v; memcpy(&v, buf.data() + (off+i)*4, 4);
+                printf(" %08x", v);
+            }
+            printf("\n");
+        }
+    }
+
+    return true;
+}
+
+static void print_usage(int, char **) {}
+
+int main(int argc, char ** argv) {
+    common_params params;
+    if (!common_params_parse(argc, argv, params, LLAMA_EXAMPLE_MAIN, print_usage)) return 1;
+    common_init();
+
+    if (params.n_predict < 0) params.n_predict = 3;
+    params.cpuparams.n_threads = 1;
+
+    diag_state state = { 0 };
+    params.cb_eval = tensor_callback;
+    params.cb_eval_user_data = &state;
+
+    auto mparams = common_model_params_to_llama(params);
+    auto * model = llama_model_load_from_file(params.model.path.c_str(), mparams);
+    if (!model) return 1;
+
+    auto cparams = common_context_params_to_llama(params);
+    auto * ctx = llama_init_from_model(model, cparams);
+    if (!ctx) return 1;
+
+    const auto * vocab = llama_model_get_vocab(model);
+    auto tokens = common_tokenize(vocab, params.prompt, true);
+
+    auto batch = llama_batch_init(tokens.size() + params.n_predict, 0, 1);
+    for (size_t i = 0; i < tokens.size(); i++)
+        common_batch_add(batch, tokens[i], i, {0}, false);
+    batch.logits[tokens.size() - 1] = true;
+
+    printf("# PROMPT EVAL (%zu tokens)\n", tokens.size());
+    state.token_idx = 0;
+    llama_decode(ctx, batch);
+
+    auto * smpl = common_sampler_init(model, params.sampling);
+    for (int i = 0; i < params.n_predict; i++) {
+        llama_token id = common_sampler_sample(smpl, ctx, -1);
+        if (llama_vocab_is_eog(vocab, id)) break;
+
+        char buf[64];
+        int len = llama_token_to_piece(vocab, id, buf, sizeof(buf) - 1, 0, true);
+        buf[len] = 0;
+        fprintf(stderr, "Token %d: id=%d '%s'\n", i, id, buf);
+
+        common_batch_clear(batch);
+        common_batch_add(batch, id, tokens.size() + i, {0}, true);
+
+        state.token_idx = i + 1;
+        printf("# TOKEN %d (id=%d)\n", i + 1, id);
+        llama_decode(ctx, batch);
+    }
+
+    common_sampler_free(smpl);
+    llama_batch_free(batch);

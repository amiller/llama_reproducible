diff --git a/tests/test-mma-accum.cu b/tests/test-mma-accum.cu
new file mode 100644
index 00000000..631a65c8
--- /dev/null
+++ b/tests/test-mma-accum.cu
@@ -0,0 +1,341 @@
+// Test MMA accumulation order on SM86 (RTX 3090)
+// B is column-major in WMMA: B[k][j] stored at B[j*ldB + k]
+
+#include <cuda_fp16.h>
+#include <mma.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <math.h>
+#include <stdint.h>
+
+using namespace nvcuda;
+
+#define M 16
+#define N 16
+#define K 16
+
+// A is row-major: A[i][k] = A[i*K+k]
+// B is col-major: B[k][j] = B[j*K+k]
+// D[i][j] = C[i][j] + sum_k A[i][k] * B[k][j]
+
+void cpu_sequential(const half *A, const half *B, const float *C, float *D) {
+    for (int i = 0; i < M; i++)
+        for (int j = 0; j < N; j++) {
+            float acc = C[i*N+j];
+            for (int k = 0; k < K; k++)
+                acc += __half2float(A[i*K+k]) * __half2float(B[j*K+k]);
+            D[i*N+j] = acc;
+        }
+}
+
+void cpu_reverse(const half *A, const half *B, const float *C, float *D) {
+    for (int i = 0; i < M; i++)
+        for (int j = 0; j < N; j++) {
+            float acc = C[i*N+j];
+            for (int k = K-1; k >= 0; k--)
+                acc += __half2float(A[i*K+k]) * __half2float(B[j*K+k]);
+            D[i*N+j] = acc;
+        }
+}
+
+void cpu_tree(const half *A, const half *B, const float *C, float *D) {
+    for (int i = 0; i < M; i++)
+        for (int j = 0; j < N; j++) {
+            float p[K];
+            for (int k = 0; k < K; k++)
+                p[k] = __half2float(A[i*K+k]) * __half2float(B[j*K+k]);
+            for (int s = 1; s < K; s *= 2)
+                for (int k = 0; k+s < K; k += s*2)
+                    p[k] += p[k+s];
+            D[i*N+j] = C[i*N+j] + p[0];
+        }
+}
+
+void cpu_twogroup(const half *A, const half *B, const float *C, float *D) {
+    for (int i = 0; i < M; i++)
+        for (int j = 0; j < N; j++) {
+            float s1 = 0, s2 = 0;
+            for (int k = 0; k < 8; k++)
+                s1 += __half2float(A[i*K+k]) * __half2float(B[j*K+k]);
+            for (int k = 8; k < 16; k++)
+                s2 += __half2float(A[i*K+k]) * __half2float(B[j*K+k]);
+            D[i*N+j] = C[i*N+j] + s1 + s2;
+        }
+}
+
+// Two-group: each group summed, then combined with fmaf
+void cpu_twogroup_fma(const half *A, const half *B, const float *C, float *D) {
+    for (int i = 0; i < M; i++)
+        for (int j = 0; j < N; j++) {
+            float s1 = 0, s2 = 0;
+            for (int k = 0; k < 8; k++)
+                s1 = fmaf(__half2float(A[i*K+k]), __half2float(B[j*K+k]), s1);
+            for (int k = 8; k < 16; k++)
+                s2 = fmaf(__half2float(A[i*K+k]), __half2float(B[j*K+k]), s2);
+            D[i*N+j] = C[i*N+j] + s1 + s2;
+        }
+}
+
+// Sequential with fmaf
+void cpu_sequential_fma(const half *A, const half *B, const float *C, float *D) {
+    for (int i = 0; i < M; i++)
+        for (int j = 0; j < N; j++) {
+            float acc = C[i*N+j];
+            for (int k = 0; k < K; k++)
+                acc = fmaf(__half2float(A[i*K+k]), __half2float(B[j*K+k]), acc);
+            D[i*N+j] = acc;
+        }
+}
+
+// FP16 references
+void cpu_f16_sequential(const half *A, const half *B, half *D) {
+    for (int i = 0; i < M; i++)
+        for (int j = 0; j < N; j++) {
+            float acc = 0;
+            for (int k = 0; k < K; k++) {
+                acc += __half2float(A[i*K+k]) * __half2float(B[j*K+k]);
+                acc = __half2float(__float2half(acc)); // truncate per step
+            }
+            D[i*N+j] = __float2half(acc);
+        }
+}
+
+void cpu_f16_f32acc(const half *A, const half *B, half *D) {
+    for (int i = 0; i < M; i++)
+        for (int j = 0; j < N; j++) {
+            float acc = 0;
+            for (int k = 0; k < K; k++)
+                acc += __half2float(A[i*K+k]) * __half2float(B[j*K+k]);
+            D[i*N+j] = __float2half(acc);
+        }
+}
+
+void cpu_f16_tree(const half *A, const half *B, half *D) {
+    for (int i = 0; i < M; i++)
+        for (int j = 0; j < N; j++) {
+            float p[K];
+            for (int k = 0; k < K; k++)
+                p[k] = __half2float(A[i*K+k]) * __half2float(B[j*K+k]);
+            for (int s = 1; s < K; s *= 2)
+                for (int k = 0; k+s < K; k += s*2)
+                    p[k] += p[k+s];
+            D[i*N+j] = __float2half(p[0]);
+        }
+}
+
+// FP16: pairs of products summed in FP32, then pairs of sums, truncate at end
+void cpu_f16_pair_f32(const half *A, const half *B, half *D) {
+    for (int i = 0; i < M; i++)
+        for (int j = 0; j < N; j++) {
+            // 8 pairs of products
+            float pairs[8];
+            for (int k = 0; k < 16; k += 2) {
+                float p0 = __half2float(A[i*K+k]) * __half2float(B[j*K+k]);
+                float p1 = __half2float(A[i*K+k+1]) * __half2float(B[j*K+k+1]);
+                pairs[k/2] = p0 + p1;
+            }
+            // Sum pairs
+            for (int s = 1; s < 8; s *= 2)
+                for (int k = 0; k+s < 8; k += s*2)
+                    pairs[k] += pairs[k+s];
+            D[i*N+j] = __float2half(pairs[0]);
+        }
+}
+
+// FP16 with fmaf sequential
+void cpu_f16_fma(const half *A, const half *B, half *D) {
+    for (int i = 0; i < M; i++)
+        for (int j = 0; j < N; j++) {
+            float acc = 0;
+            for (int k = 0; k < K; k++)
+                acc = fmaf(__half2float(A[i*K+k]), __half2float(B[j*K+k]), acc);
+            D[i*N+j] = __float2half(acc);
+        }
+}
+
+__global__ void gpu_mma_f32(const half *A, const half *B, float *D) {
+    wmma::fragment<wmma::matrix_a, 16, 16, 16, half, wmma::row_major> a;
+    wmma::fragment<wmma::matrix_b, 16, 16, 16, half, wmma::col_major> b;
+    wmma::fragment<wmma::accumulator, 16, 16, 16, float> c;
+    wmma::load_matrix_sync(a, A, 16);
+    wmma::load_matrix_sync(b, B, 16);
+    wmma::fill_fragment(c, 0.0f);
+    wmma::mma_sync(c, a, b, c);
+    wmma::store_matrix_sync(D, c, 16, wmma::mem_row_major);
+}
+
+__global__ void gpu_mma_f16(const half *A, const half *B, half *D) {
+    wmma::fragment<wmma::matrix_a, 16, 16, 16, half, wmma::row_major> a;
+    wmma::fragment<wmma::matrix_b, 16, 16, 16, half, wmma::col_major> b;
+    wmma::fragment<wmma::accumulator, 16, 16, 16, half> c;
+    wmma::load_matrix_sync(a, A, 16);
+    wmma::load_matrix_sync(b, B, 16);
+    wmma::fill_fragment(c, __float2half(0.0f));
+    wmma::mma_sync(c, a, b, c);
+    wmma::store_matrix_sync(D, c, 16, wmma::mem_row_major);
+}
+
+__global__ void gpu_mma_f32_chained(const half *A, const half *B, float *D) {
+    wmma::fragment<wmma::matrix_a, 16, 16, 16, half, wmma::row_major> a;
+    wmma::fragment<wmma::matrix_b, 16, 16, 16, half, wmma::col_major> b;
+    wmma::fragment<wmma::accumulator, 16, 16, 16, float> c;
+    wmma::fill_fragment(c, 0.0f);
+    for (int t = 0; t < 8; t++) {
+        wmma::load_matrix_sync(a, A + t*256, 16);
+        wmma::load_matrix_sync(b, B + t*256, 16);
+        wmma::mma_sync(c, a, b, c);
+    }
+    wmma::store_matrix_sync(D, c, 16, wmma::mem_row_major);
+}
+
+void fill_random(half *d, int n, float scale, unsigned seed) {
+    srand(seed);
+    for (int i = 0; i < n; i++)
+        d[i] = __float2half(((float)rand()/RAND_MAX*2-1) * scale);
+}
+
+int cmp_f32(const float *gpu, const float *cpu, int n, const char *name) {
+    int miss = 0;
+    float maxe = 0;
+    for (int i = 0; i < n; i++) {
+        uint32_t g, c; memcpy(&g, &gpu[i], 4); memcpy(&c, &cpu[i], 4);
+        if (g != c) { miss++; float e = fabsf(gpu[i]-cpu[i]); if (e>maxe) maxe=e; }
+    }
+    printf("  %-20s: %3d/%d match", name, n-miss, n);
+    if (miss) printf("  maxerr=%.3e", maxe);
+    printf("\n");
+    return miss == 0;
+}
+
+int cmp_f16(const half *gpu, const half *cpu, int n, const char *name) {
+    int miss = 0;
+    for (int i = 0; i < n; i++) {
+        uint16_t g, c; memcpy(&g, &gpu[i], 2); memcpy(&c, &cpu[i], 2);
+        if (g != c) miss++;
+    }
+    printf("  %-20s: %3d/%d match", name, n-miss, n);
+    if (miss) printf("  (%d mismatches)", miss);
+    printf("\n");
+    return miss == 0;
+}
+
+int main() {
+    half *hA = (half*)malloc(M*K*2), *hB = (half*)malloc(K*N*2);
+    float C0[M*N] = {0}, D_gpu_f32[M*N], D_ref[M*N];
+    half D_gpu_f16[M*N], D_ref_f16[M*N];
+
+    half *dA, *dB; float *dD_f32; half *dD_f16;
+    cudaMalloc(&dA, M*K*2); cudaMalloc(&dB, K*N*2);
+    cudaMalloc(&dD_f32, M*N*4); cudaMalloc(&dD_f16, M*N*2);
+
+    unsigned seeds[] = {42, 137, 2718, 31415, 99999};
+    float scales[] = {0.1f, 1.0f, 10.0f, 100.0f};
+    int pass_f32[6] = {0}, pass_f16[5] = {0}, tests = 0;
+
+    printf("=== FP32 ACCUMULATOR (Q·K^T path) ===\n");
+    for (float sc : scales) {
+        for (unsigned s : seeds) {
+            fill_random(hA, M*K, sc, s);
+            fill_random(hB, K*N, sc, s+1000);
+            cudaMemcpy(dA, hA, M*K*2, cudaMemcpyHostToDevice);
+            cudaMemcpy(dB, hB, K*N*2, cudaMemcpyHostToDevice);
+            gpu_mma_f32<<<1,32>>>(dA, dB, dD_f32);
+            cudaDeviceSynchronize();
+            cudaMemcpy(D_gpu_f32, dD_f32, M*N*4, cudaMemcpyDeviceToHost);
+
+            printf("\n  sc=%.1f seed=%u:\n", sc, s);
+            cpu_sequential(hA, hB, C0, D_ref);       pass_f32[0] += cmp_f32(D_gpu_f32, D_ref, M*N, "sequential");
+            cpu_reverse(hA, hB, C0, D_ref);           pass_f32[1] += cmp_f32(D_gpu_f32, D_ref, M*N, "reverse");
+            cpu_tree(hA, hB, C0, D_ref);              pass_f32[2] += cmp_f32(D_gpu_f32, D_ref, M*N, "tree");
+            cpu_twogroup(hA, hB, C0, D_ref);          pass_f32[3] += cmp_f32(D_gpu_f32, D_ref, M*N, "two-group");
+            cpu_twogroup_fma(hA, hB, C0, D_ref);      pass_f32[4] += cmp_f32(D_gpu_f32, D_ref, M*N, "twogroup-fma");
+            cpu_sequential_fma(hA, hB, C0, D_ref);    pass_f32[5] += cmp_f32(D_gpu_f32, D_ref, M*N, "sequential-fma");
+            tests++;
+        }
+    }
+
+    printf("\n=== FP16 ACCUMULATOR (softmax·V path) ===\n");
+    for (float sc : scales) {
+        for (unsigned s : seeds) {
+            fill_random(hA, M*K, sc, s);
+            fill_random(hB, K*N, sc, s+1000);
+            cudaMemcpy(dA, hA, M*K*2, cudaMemcpyHostToDevice);
+            cudaMemcpy(dB, hB, K*N*2, cudaMemcpyHostToDevice);
+            gpu_mma_f16<<<1,32>>>(dA, dB, dD_f16);
+            cudaDeviceSynchronize();
+            cudaMemcpy(D_gpu_f16, dD_f16, M*N*2, cudaMemcpyDeviceToHost);
+
+            printf("\n  sc=%.1f seed=%u:\n", sc, s);
+            cpu_f16_sequential(hA, hB, D_ref_f16);  pass_f16[0] += cmp_f16(D_gpu_f16, D_ref_f16, M*N, "f16_seq_trunc");
+            cpu_f16_f32acc(hA, hB, D_ref_f16);      pass_f16[1] += cmp_f16(D_gpu_f16, D_ref_f16, M*N, "f16_f32acc");
+            cpu_f16_tree(hA, hB, D_ref_f16);        pass_f16[2] += cmp_f16(D_gpu_f16, D_ref_f16, M*N, "f16_tree");
+            cpu_f16_pair_f32(hA, hB, D_ref_f16);    pass_f16[3] += cmp_f16(D_gpu_f16, D_ref_f16, M*N, "f16_pair_f32");
+            cpu_f16_fma(hA, hB, D_ref_f16);         pass_f16[4] += cmp_f16(D_gpu_f16, D_ref_f16, M*N, "f16_fma");
+        }
+    }
+
+    // Chained test
+    printf("\n=== CHAINED 8x MMA (K=128, FP32 acc) ===\n");
+    half *hA8 = (half*)malloc(M*128*2), *hB8 = (half*)malloc(128*N*2);
+    half *dA8, *dB8;
+    cudaMalloc(&dA8, M*128*2); cudaMalloc(&dB8, 128*N*2);
+    int chain_pass[2] = {0};
+
+    for (unsigned s : seeds) {
+        fill_random(hA8, M*128, 1.0f, s);
+        fill_random(hB8, 128*N, 1.0f, s+5000);
+        cudaMemcpy(dA8, hA8, M*128*2, cudaMemcpyHostToDevice);
+        cudaMemcpy(dB8, hB8, 128*N*2, cudaMemcpyHostToDevice);
+        gpu_mma_f32_chained<<<1,32>>>(dA8, dB8, dD_f32);
+        cudaDeviceSynchronize();
+        cudaMemcpy(D_gpu_f32, dD_f32, M*N*4, cudaMemcpyDeviceToHost);
+
+        printf("\n  seed=%u:\n", s);
+
+        // Chained sequential: tile 0..7, each sequential in k
+        memset(D_ref, 0, M*N*4);
+        for (int t = 0; t < 8; t++) {
+            float tmp[M*N];
+            cpu_sequential(hA8+t*256, hB8+t*256, D_ref, tmp);
+            memcpy(D_ref, tmp, M*N*4);
+        }
+        chain_pass[0] += cmp_f32(D_gpu_f32, D_ref, M*N, "chain_seq");
+
+        // Chained fma
+        memset(D_ref, 0, M*N*4);
+        for (int t = 0; t < 8; t++) {
+            float tmp[M*N];
+            cpu_sequential_fma(hA8+t*256, hB8+t*256, D_ref, tmp);
+            memcpy(D_ref, tmp, M*N*4);
+        }
+        chain_pass[1] += cmp_f32(D_gpu_f32, D_ref, M*N, "chain_fma");
+    }
+
+    // Self-consistency
+    printf("\n=== GPU SELF-CONSISTENCY ===\n");
+    fill_random(hA, M*K, 100.0f, 77777);
+    fill_random(hB, K*N, 100.0f, 88888);
+    cudaMemcpy(dA, hA, M*K*2, cudaMemcpyHostToDevice);
+    cudaMemcpy(dB, hB, K*N*2, cudaMemcpyHostToDevice);
+    float D1[M*N], D2[M*N];
+    gpu_mma_f32<<<1,32>>>(dA, dB, dD_f32); cudaDeviceSynchronize();
+    cudaMemcpy(D1, dD_f32, M*N*4, cudaMemcpyDeviceToHost);
+    gpu_mma_f32<<<1,32>>>(dA, dB, dD_f32); cudaDeviceSynchronize();
+    cudaMemcpy(D2, dD_f32, M*N*4, cudaMemcpyDeviceToHost);
+    int sm = 0;
+    for (int i = 0; i < M*N; i++) { uint32_t a,b; memcpy(&a,&D1[i],4); memcpy(&b,&D2[i],4); if (a==b) sm++; }
+    printf("  run1 vs run2: %d/%d match\n", sm, M*N);
+
+    printf("\n=== SCOREBOARD (%d test configs) ===\n", tests);
+    const char *names_f32[] = {"sequential","reverse","tree","two-group","twogroup-fma","sequential-fma"};
+    for (int i = 0; i < 6; i++)
+        printf("  FP32 %-20s: %d/%d perfect\n", names_f32[i], pass_f32[i], tests);
+    const char *names_f16[] = {"f16_seq_trunc","f16_f32acc","f16_tree","f16_pair_f32","f16_fma"};
+    for (int i = 0; i < 5; i++)
+        printf("  FP16 %-20s: %d/%d perfect\n", names_f16[i], pass_f16[i], tests);
+    printf("  CHAIN %-20s: %d/%d perfect\n", "chain_seq", chain_pass[0], 5);
+    printf("  CHAIN %-20s: %d/%d perfect\n", "chain_fma", chain_pass[1], 5);
+
+    free(hA); free(hB); free(hA8); free(hB8);
+    cudaFree(dA); cudaFree(dB); cudaFree(dD_f32); cudaFree(dD_f16); cudaFree(dA8); cudaFree(dB8);
+}

+// Deterministic Q4_K x Q8_1 dot product — matches GPU vecdotq.cuh exactly
+// CPU scalar emulation of the GPU's DP4A-based Q4_K x Q8_1 path.
+// Uses the same scale unpacking, 4-bit extraction, and FP32 accumulation
+// as vec_dot_q4_K_q8_1_impl_vmmq on CUDA.
+static int dp4a_cpu(int a, int b, int c) {
+    const int8_t *va = (const int8_t *)&a;
+    const int8_t *vb = (const int8_t *)&b;
+    c += (int)va[0]*vb[0] + (int)va[1]*vb[1] + (int)va[2]*vb[2] + (int)va[3]*vb[3];
+    return c;
+}
+
+// Compute one Q4_K thread's partial dot product for a single block
+static inline float q4k_partial(const block_q4_K * bq4, const block_q8_1 * bq8, int iqs) {
+    const int bq8_offset = 2 * ((iqs / 2) / 4);
+    const int pos = (iqs / 2) % 4;
+
+    const int *q4 = (const int *)(bq4->qs + 16 * bq8_offset + 4 * pos);
+    int v[2] = { q4[0], q4[4] };
+
+    const uint16_t *scales = (const uint16_t *)bq4->scales;
+    uint16_t aux[2];
+    const int j = bq8_offset / 2;
+    if (j < 2) {
+        aux[0] = scales[j + 0] & 0x3f3f;
+        aux[1] = scales[j + 2] & 0x3f3f;
+    } else {
+        aux[0] = ((scales[j + 2] >> 0) & 0x0f0f) | ((scales[j - 2] & 0xc0c0) >> 2);
+        aux[1] = ((scales[j + 2] >> 4) & 0x0f0f) | ((scales[j - 0] & 0xc0c0) >> 2);
+    }
+    const uint8_t *sc = (const uint8_t *)aux;
+    const uint8_t *m  = sc + 2;
+
+    float sumf_d = 0.0f, sumf_m = 0.0f;
+    int u[4];
+    float d8[2];
+
+    for (int qi = 0; qi < 2; ++qi) {
+        const block_q8_1 *bq8i = bq8 + bq8_offset + qi;
+        d8[qi] = GGML_CPU_FP16_TO_FP32(bq8i->d);
+        const int *q8 = (const int *)bq8i->qs + pos;
+        u[2 * qi + 0] = q8[0];
+        u[2 * qi + 1] = q8[4];
+    }
+
+    for (int qi = 0; qi < 2; ++qi) {
+        const int v0i = (v[0] >> (4 * qi)) & 0x0F0F0F0F;
+        const int v1i = (v[1] >> (4 * qi)) & 0x0F0F0F0F;
+        const int dot1 = dp4a_cpu(v1i, u[2*qi+1], dp4a_cpu(v0i, u[2*qi+0], 0));
+        const int dot2 = dp4a_cpu(0x01010101, u[2*qi+1], dp4a_cpu(0x01010101, u[2*qi+0], 0));

--- /dev/null
+++ b/ggml/src/ggml-deterministic.h
@@ -0,0 +1,162 @@
+// Portable math functions for GPU-CPU deterministic parity.
+// These use only FMA + basic IEEE ops, producing bitwise-identical
+// results on both CUDA and x86 when compiled with FMA support.
+#pragma once
+
+#ifdef __CUDA_ARCH__
+#define DET_FMA(a,b,c) __fmaf_rn(a,b,c)
+#else
+#include <math.h>
+#define DET_FMA(a,b,c) fmaf(a,b,c)
+#endif
+
+// Portable expf using Cody-Waite range reduction + Horner polynomial.
+// Max error: ~1 ULP. Produces identical results on CPU and GPU.
+static inline
+#ifdef __CUDA_ARCH__
+__device__
+#endif
+float expf_det(float x) {
+    x = fmaxf(x, -87.3f);
+    x = fminf(x, 88.7f);
+
+    const float log2e = 1.442695040888963f;
+    const float ln2_hi = 0.693145751953125f;
+    const float ln2_lo = 1.42860676533018e-06f;
+
+    float n = rintf(x * log2e);
+    float r = DET_FMA(n, -ln2_hi, x);
+    r = DET_FMA(n, -ln2_lo, r);
+
+    // Minimax polynomial for exp(r) on [-ln2/2, ln2/2]
+    float p = 1.9875691500e-4f;
+    p = DET_FMA(p, r, 1.3981999507e-3f);
+    p = DET_FMA(p, r, 8.3334519073e-3f);
+    p = DET_FMA(p, r, 4.1665795894e-2f);
+    p = DET_FMA(p, r, 1.6666665459e-1f);
+    p = DET_FMA(p, r, 5.0000001201e-1f);
+    p = DET_FMA(p, r * r, r);
+    p = p + 1.0f;
+
+    // Reconstruct: exp(x) = p * 2^n via exponent bit manipulation
+    int ni = (int)n;
+    unsigned int bits;
+    memcpy(&bits, &p, sizeof(bits));
+    bits += (unsigned int)(ni) << 23;
+    float result;
+    memcpy(&result, &bits, sizeof(result));
+    return result;
+}
+
+// Portable integer power using binary exponentiation.
+// Uses only IEEE mul — bitwise identical on CPU and GPU.
+static inline
+#ifdef __CUDA_ARCH__
+__device__
+#endif
+float powf_int_det(float base, int exp) {
+    float result = 1.0f;
+    float p = base;
+    int e = exp < 0 ? -exp : exp;
+    while (e > 0) {
+        if (e & 1) result *= p;
+        p *= p;
+        e >>= 1;
+    }
+    return exp < 0 ? 1.0f / result : result;
+}
+
+// Portable sinf/cosf using Cody-Waite range reduction + minimax polynomials.
+// Produces bitwise-identical results on CPU and GPU.
+static inline
+#ifdef __CUDA_ARCH__
+__device__
+#endif
+void sincosf_det(float x, float *sp, float *cp) {
+    // Cody-Waite constants for π/2
+    const float pio2_hi = 1.5707963267341256e+00f; // 0x3FC90FDA
+    const float pio2_lo = 1.5893254773528196e-08f; // 0x33A22168
+
+    // Range reduce: n = round(x / (π/2))
+    float n = rintf(x * 0.6366197723675814f);  // 2/π
+    float r = DET_FMA(n, -pio2_hi, x);
+    r = DET_FMA(n, -pio2_lo, r);
+
+    float r2 = r * r;
+
+    // Minimax polynomial for sin(r) on [-π/4, π/4]: r - r³/6 + r⁵/120 - ...
+    float sr = DET_FMA(-1.9515295891e-4f, r2, 8.3321608736e-3f);
+    sr = DET_FMA(sr, r2, -1.6666654611e-1f);
+    sr = DET_FMA(sr, r2 * r, r);
+
+    // Minimax polynomial for cos(r) on [-π/4, π/4]: 1 - r²/2 + r⁴/24 - ...
+    float cr = DET_FMA(2.4430318451e-5f, r2, -1.3888580016e-3f);
+    cr = DET_FMA(cr, r2, 4.1666641831e-2f);
+    cr = DET_FMA(cr, r2, -4.9999997020e-1f);
+    cr = DET_FMA(cr, r2, 1.0f);
+
+    // Select based on quadrant (n mod 4)
+    int ni = (int)n;
+    int q = ni & 3;
+    if (ni < 0) q = ((ni % 4) + 4) & 3;
+
+    float s, c;
+    switch (q) {
+        case 0: s =  sr; c =  cr; break;
+        case 1: s =  cr; c = -sr; break;
+        case 2: s = -sr; c = -cr; break;
+        default: s = -cr; c =  sr; break;
+    }
+    *sp = s;
+    *cp = c;
+}
+
+// Portable logf using Cody-Waite style reduction.
+// Uses the identity: log(x) = log(2) * (e + log2(m)) where x = m * 2^e, 1 <= m < 2
+// Then log2(m) ≈ polynomial on [1,2)
+static inline
+#ifdef __CUDA_ARCH__
+__device__
+#endif
+float logf_det(float x) {
+    // Decompose x = m * 2^e via bit manipulation
+    union { float f; uint32_t u; } conv;
+    conv.f = x;
+    int e = (int)((conv.u >> 23) & 0xFF) - 127;
+    conv.u = (conv.u & 0x007FFFFF) | 0x3F800000; // m in [1, 2)
+    float m = conv.f;
+
+    // Reduce to f = (m-1)/(m+1), then log(m) = 2*f*(1 + f²/3 + f⁴/5 + ...)
+    float f = (m - 1.0f) / (m + 1.0f);
+    float f2 = f * f;
+
+    // Minimax polynomial: log(m) ≈ 2*f * (1 + c1*f² + c2*f⁴ + c3*f⁶)
+    float p = DET_FMA(0.2424046874f, f2, 0.4005714059f);
+    p = DET_FMA(p, f2, 0.6666666269f);
+    p = DET_FMA(p, f2, 2.0f);
+    float log_m = f * p;
+
+    // log(x) = e * ln(2) + log(m)
+    const float ln2 = 0.6931471805599453f;
+    return DET_FMA((float)e, ln2, log_m);
+}
+
+// Portable softplus: log(1 + exp(x))
+static inline
+#ifdef __CUDA_ARCH__
+__device__
+#endif
+float softplus_det(float x) {
+    if (x > 20.0f) return x;
+    float ex = expf_det(x);
+    return logf_det(1.0f + ex);
+}
+
+// Portable SiLU using expf_det
+static inline
+#ifdef __CUDA_ARCH__
+__device__
+#endif
+float silu_det(float x) {
+    return x / (1.0f + expf_det(-x));
+}

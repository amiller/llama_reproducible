@@ -386,6 +386,13 @@ void quantize_row_q8_0(const float * GGML_RESTRICT x, void * GGML_RESTRICT vy, i
 }
 
 void quantize_row_q8_1(const float * GGML_RESTRICT x, void * GGML_RESTRICT vy, int64_t k) {
+    // x86 SIMD version uses 127/max * x (reciprocal multiply).
+    // GPU uses roundf(xi / d) where d = max/127. These differ for some values.
+    // In deterministic mode, fall back to the ref version which uses direct division.
+    if (ggml_is_deterministic()) {
+        quantize_row_q8_1_ref(x, vy, k);
+        return;
+    }
     assert(k % QK8_1 == 0);
     const int nb = k / QK8_1;
 

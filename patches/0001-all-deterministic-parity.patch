diff --git a/ggml/src/ggml-cuda/mmq-det.cu b/ggml/src/ggml-cuda/mmq-det.cu
new file mode 100644
index 00000000..d57af9f6
--- /dev/null
+++ b/ggml/src/ggml-cuda/mmq-det.cu
@@ -0,0 +1,161 @@
+// Deterministic MMQ kernel using dp4a (integer ALU) instead of tensor core MMA.
+// This file is compiled as a separate translation unit with MMA macros undefined,
+// so all static __device__ functions (load_tiles, vec_dot, write_back, mul_mat_q)
+// compile their dp4a code paths — even on GPUs that have tensor cores.
+//
+// The dp4a accumulation is thread-local (no inter-warp reduction), making it
+// straightforward to write a bitwise-matching CPU shadow for deterministic verification.
+
+#include "common.cuh"
+
+// Force dp4a path by undefining all MMA/tensor core macros.
+// common.cuh defines these based on __CUDA_ARCH__, but we want dp4a regardless.
+#undef TURING_MMA_AVAILABLE
+#undef VOLTA_MMA_AVAILABLE
+#undef AMD_MFMA_AVAILABLE
+#undef AMD_WMMA_AVAILABLE
+#undef BLACKWELL_MMA_AVAILABLE
+
+#include "vecdotq.cuh"
+#include "mma.cuh"
+#include "mmq.cuh"
+#include "quantize.cuh"
+
+// ---- dp4a dispatch with correct parameters ----
+
+template <ggml_type type>
+static void mul_mat_q_det_case(ggml_backend_cuda_context & ctx, const mmq_args & args, cudaStream_t stream) {
+    const int id = ggml_cuda_get_device();
+    const int cc = ggml_cuda_info().devices[id].cc;
+    const size_t smpbo = ggml_cuda_info().devices[id].smpbo;
+    const int warp_size = ggml_cuda_info().devices[id].warp_size;
+    const int nwarps = 256 / warp_size;
+    const int mmq_y = get_mmq_y_host(cc);
+
+    constexpr int mmq_x_max = MMQ_DP4A_MAX_BATCH_SIZE;
+
+    int mmq_x_best = 0;
+    int ntiles_x_best = INT_MAX;
+
+    for (int mmq_x = 8; mmq_x <= mmq_x_max && ntiles_x_best > 1; mmq_x += 8) {
+        const tile_x_sizes txs = mmq_get_dp4a_tile_x_sizes(type, mmq_y);
+        const size_t nbs_ids = mmq_x * sizeof(int);
+        const size_t nbs_x = txs.qs*sizeof(int) + txs.dm*sizeof(half2) + txs.sc*sizeof(int);
+        const size_t nbs_y = mmq_x * sizeof(block_q8_1_mmq);
+        const size_t nbytes_shared = nbs_ids + nbs_x + GGML_PAD(nbs_y, nwarps*warp_size*sizeof(int));
+
+        if (nbytes_shared > smpbo) continue;
+
+        const int ntiles_x = (args.ncols_max + mmq_x - 1) / mmq_x;
+        if (ntiles_x < ntiles_x_best) {
+            mmq_x_best = mmq_x;
+            ntiles_x_best = ntiles_x;
+        }
+    }
+
+    switch (mmq_x_best) {
+        case  8: launch_mul_mat_q<type,  8>(ctx, args, stream); break;
+        case 16: launch_mul_mat_q<type, 16>(ctx, args, stream); break;
+        case 24: launch_mul_mat_q<type, 24>(ctx, args, stream); break;
+        case 32: launch_mul_mat_q<type, 32>(ctx, args, stream); break;
+        case 40: launch_mul_mat_q<type, 40>(ctx, args, stream); break;
+        case 48: launch_mul_mat_q<type, 48>(ctx, args, stream); break;
+        case 56: launch_mul_mat_q<type, 56>(ctx, args, stream); break;
+        case 64: launch_mul_mat_q<type, 64>(ctx, args, stream); break;
+        default:
+            fprintf(stderr, "mmq-det: mmq_x_best=%d\n", mmq_x_best);
+            GGML_ABORT("fatal error");
+            break;
+    }
+}
+
+static void mmq_det_switch_type(ggml_backend_cuda_context & ctx, const mmq_args & args, cudaStream_t stream) {
+    switch (args.type_x) {
+        case GGML_TYPE_Q4_0:    mul_mat_q_det_case<GGML_TYPE_Q4_0>(ctx, args, stream);    break;
+        case GGML_TYPE_Q4_1:    mul_mat_q_det_case<GGML_TYPE_Q4_1>(ctx, args, stream);    break;
+        case GGML_TYPE_Q5_0:    mul_mat_q_det_case<GGML_TYPE_Q5_0>(ctx, args, stream);    break;
+        case GGML_TYPE_Q5_1:    mul_mat_q_det_case<GGML_TYPE_Q5_1>(ctx, args, stream);    break;
+        case GGML_TYPE_Q8_0:    mul_mat_q_det_case<GGML_TYPE_Q8_0>(ctx, args, stream);    break;
+        case GGML_TYPE_Q2_K:    mul_mat_q_det_case<GGML_TYPE_Q2_K>(ctx, args, stream);    break;
+        case GGML_TYPE_Q3_K:    mul_mat_q_det_case<GGML_TYPE_Q3_K>(ctx, args, stream);    break;
+        case GGML_TYPE_Q4_K:    mul_mat_q_det_case<GGML_TYPE_Q4_K>(ctx, args, stream);    break;
+        case GGML_TYPE_Q5_K:    mul_mat_q_det_case<GGML_TYPE_Q5_K>(ctx, args, stream);    break;
+        case GGML_TYPE_Q6_K:    mul_mat_q_det_case<GGML_TYPE_Q6_K>(ctx, args, stream);    break;
+        case GGML_TYPE_IQ2_XXS: mul_mat_q_det_case<GGML_TYPE_IQ2_XXS>(ctx, args, stream); break;
+        case GGML_TYPE_IQ2_XS:  mul_mat_q_det_case<GGML_TYPE_IQ2_XS>(ctx, args, stream);  break;
+        case GGML_TYPE_IQ2_S:   mul_mat_q_det_case<GGML_TYPE_IQ2_S>(ctx, args, stream);   break;
+        case GGML_TYPE_IQ3_XXS: mul_mat_q_det_case<GGML_TYPE_IQ3_XXS>(ctx, args, stream); break;
+        case GGML_TYPE_IQ3_S:   mul_mat_q_det_case<GGML_TYPE_IQ3_S>(ctx, args, stream);   break;
+        case GGML_TYPE_IQ1_S:   mul_mat_q_det_case<GGML_TYPE_IQ1_S>(ctx, args, stream);   break;
+        case GGML_TYPE_IQ4_NL:  mul_mat_q_det_case<GGML_TYPE_IQ4_NL>(ctx, args, stream);  break;
+        case GGML_TYPE_IQ4_XS:  mul_mat_q_det_case<GGML_TYPE_IQ4_XS>(ctx, args, stream);  break;
+        default: GGML_ABORT("unsupported type for det mmq"); break;
+    }
+}
+
+// ---- Tensor-level entry point ----
+
+void ggml_cuda_mul_mat_q_det(
+        ggml_backend_cuda_context & ctx, const ggml_tensor * src0, const ggml_tensor * src1,
+        const ggml_tensor * ids, ggml_tensor * dst) {
+    GGML_ASSERT(src1->type == GGML_TYPE_F32);
+    GGML_ASSERT(dst->type  == GGML_TYPE_F32);
+    GGML_ASSERT(!ids);
+
+    GGML_TENSOR_BINARY_OP_LOCALS;
+
+    cudaStream_t stream = ctx.stream();
+    const size_t ts_src0 = ggml_type_size(src0->type);
+    const size_t ts_src1 = ggml_type_size(src1->type);
+    const size_t ts_dst  = ggml_type_size(dst->type);
+
+    GGML_ASSERT(nb00 == ts_src0);
+    GGML_ASSERT(nb10 == ts_src1);
+    GGML_ASSERT(nb0  == ts_dst);
+
+    const char  * src0_d = (const char  *) src0->data;
+    const float * src1_d = (const float *) src1->data;
+    float       *  dst_d = (float       *)  dst->data;
+
+    if (ggml_backend_buffer_get_usage(src0->buffer) == GGML_BACKEND_BUFFER_USAGE_COMPUTE) {
+        const size_t size_data  = ggml_nbytes(src0);
+        const size_t size_alloc = ggml_backend_buffer_get_alloc_size(src0->buffer, src0);
+        if (size_alloc > size_data) {
+            GGML_ASSERT(ggml_is_contiguously_allocated(src0));
+            GGML_ASSERT(!src0->view_src);
+            CUDA_CHECK(cudaMemsetAsync((char *) src0->data + size_data, 0, size_alloc - size_data, stream));
+        }
+    }
+
+    const int64_t ne10_padded = GGML_PAD(ne10, MATRIX_ROW_PADDING);
+    const int64_t s01 = src0->nb[1] / ts_src0;
+    const int64_t s1  =  dst->nb[1] / ts_dst;
+    const int64_t s02 = src0->nb[2] / ts_src0;
+    const int64_t s2  =  dst->nb[2] / ts_dst;
+    const int64_t s03 = src0->nb[3] / ts_src0;
+    const int64_t s3  =  dst->nb[3] / ts_dst;
+
+    const size_t nbytes_src1_q8_1 = ne13*ne12 * ne11*ne10_padded * sizeof(block_q8_1)/QK8_1 +
+        MMQ_DP4A_MAX_BATCH_SIZE*sizeof(block_q8_1_mmq);
+    ggml_cuda_pool_alloc<char> src1_q8_1(ctx.pool(), nbytes_src1_q8_1);
+
+    {
+        const int64_t s11 = src1->nb[1] / ts_src1;
+        const int64_t s12 = src1->nb[2] / ts_src1;
+        const int64_t s13 = src1->nb[3] / ts_src1;
+        quantize_mmq_q8_1_cuda(src1_d, nullptr, src1_q8_1.get(), src0->type, ne10, s11, s12, s13, ne10_padded,
+                               ne11, ne12, ne13, stream);
+        CUDA_CHECK(cudaGetLastError());
+    }
+
+    const int64_t s12 = ne11 * ne10_padded * sizeof(block_q8_1) / (QK8_1 * sizeof(int));
+    const int64_t s13 = ne12*s12;
+
+    const mmq_args args = {
+        src0_d, src0->type, (const int *) src1_q8_1.ptr, nullptr, nullptr, dst_d,
+        ne00, ne01, ne1, s01, ne11, s1,
+        ne02, ne12, s02, s12, s2,
+        ne03, ne13, s03, s13, s3,
+        false, ne1};  // use_stream_k = false for dp4a
+    mmq_det_switch_type(ctx, args, stream);
+}

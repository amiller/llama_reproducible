+// Deterministic overrides: use Q8_1 quantization for K-quant types to match GPU's mmvq path
+static inline enum ggml_type det_vec_dot_type(enum ggml_type src0_type) {
+    enum ggml_type vdt = type_traits_cpu[src0_type].vec_dot_type;
+    if (ggml_is_deterministic() && (src0_type == GGML_TYPE_Q4_K || src0_type == GGML_TYPE_Q5_K ||
+                                    src0_type == GGML_TYPE_Q6_K || src0_type == GGML_TYPE_Q8_0 ||
+                                    src0_type == GGML_TYPE_IQ4_XS || src0_type == GGML_TYPE_IQ4_NL)) {
+        vdt = GGML_TYPE_Q8_1;
+    }
+    return vdt;
+}
+
+// Select det vec_dot. Currently uses mmvq shadow for all batch sizes.
+// dp4a mmq shadows exist (ggml_vec_dot_q4_K_q8_1_det_mmq) but dp4a mmq is slower
+// than mmvq-4col for large models (27B+), so mmvq is used for all det matmul.
+static inline ggml_vec_dot_t det_vec_dot_ne1(enum ggml_type src0_type, int64_t ne1) {
+    ggml_vec_dot_t vd = type_traits_cpu[src0_type].vec_dot;
+    if (ggml_is_deterministic()) {
+        if (src0_type == GGML_TYPE_Q4_K)   vd = ggml_vec_dot_q4_K_q8_1_det;
+        if (src0_type == GGML_TYPE_Q5_K)   vd = ggml_vec_dot_q5_K_q8_1_det;
+        if (src0_type == GGML_TYPE_Q6_K)   vd = ggml_vec_dot_q6_K_q8_1_det;
+        if (src0_type == GGML_TYPE_Q8_0)   vd = ggml_vec_dot_q8_0_q8_1_det;
+        if (src0_type == GGML_TYPE_IQ4_XS) vd = ggml_vec_dot_iq4_xs_q8_1_det;
+        if (src0_type == GGML_TYPE_IQ4_NL) vd = ggml_vec_dot_iq4_nl_q8_1_det;
+        if (src0_type == GGML_TYPE_F32)    vd = ggml_vec_dot_f32_det;
+    }
+    GGML_UNUSED(ne1);
+    return vd;
+}
+
+static inline ggml_vec_dot_t det_vec_dot(enum ggml_type src0_type) {
+    return det_vec_dot_ne1(src0_type, 1);
+}
+
+static inline ggml_from_float_t det_from_float(enum ggml_type vec_dot_type, enum ggml_type src0_type, int64_t ne1) {
+    GGML_UNUSED(src0_type); GGML_UNUSED(ne1);
+    return type_traits_cpu[vec_dot_type].from_float;
+}

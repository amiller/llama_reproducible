+// Deterministic F32 dot product matching GPU mmvf kernel accumulation order.
+// GPU: block_size threads, each accumulates n/(2*block_size) float2 pairs, then warp+inter-warp reduce.
+void ggml_vec_dot_f32_det(int n, float * GGML_RESTRICT s, size_t bs, const void * GGML_RESTRICT vx, size_t bx, const void * GGML_RESTRICT vy, size_t by, int nrc) {
+    assert(nrc == 1);
+    UNUSED(nrc); UNUSED(bx); UNUSED(by); UNUSED(bs);
+
+    const float * x = vx;
+    const float * y = vy;
+    const int ncols2 = n / 2;
+
+    // Match GPU: block_size chosen to minimize iterations (same heuristic as mmvf.cu)
+    int block_size = 32;
+    for (int bs_try = 64; bs_try <= 256; bs_try += 32) {
+        if ((ncols2 + bs_try - 1) / bs_try < (ncols2 + block_size - 1) / block_size)
+            block_size = bs_try;
+    }
+
+    const int WARP_SIZE = 32;
+    const int nwarps = block_size / WARP_SIZE;
+
+    // Phase 1: per-thread accumulation (float2 pairs)
+    float tmp[256]; // max block_size
+    for (int tid = 0; tid < block_size; tid++) {
+        float sum = 0.0f;
+        for (int col2 = tid; col2 < ncols2; col2 += block_size) {
+            sum += x[2*col2]   * y[2*col2];
+            sum += x[2*col2+1] * y[2*col2+1];
+        }
+        tmp[tid] = sum;
+    }
+
+    // Phase 2: warp butterfly reduction
+    float warp_sums[8]; // max nwarps
+    for (int w = 0; w < nwarps; w++) {

+// Sequential cumsum for deterministic mode — matches CPU accumulation order.
+template<typename T>
+static __global__ void cumsum_sequential_kernel(
+        const T * __restrict__ src, T * __restrict__ dst,
+        const int64_t ne00, const int64_t ne01, const int64_t ne02, const int64_t ne03,
+        const int64_t s01, const int64_t s02, const int64_t s03,
+        const int64_t  s1, const int64_t  s2, const int64_t  s3) {
+    const int64_t i1 = blockIdx.x;
+    const int64_t i2 = blockIdx.y;
+    const int64_t i3 = blockIdx.z;
+    if (i1 >= ne01 || i2 >= ne02 || i3 >= ne03) return;
+    if (threadIdx.x != 0) return;
+    const T * src_row = src + i1*s01 + i2*s02 + i3*s03;
+    T *       dst_row = dst + i1*s1  + i2*s2  + i3*s3;
+    T acc = T(0);
+    for (int64_t i = 0; i < ne00; i++) {
+        acc += src_row[i];
+        dst_row[i] = acc;
+    }

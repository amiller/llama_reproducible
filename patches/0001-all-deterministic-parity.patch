+            int nxt = 1 - cur;
+            for (int lane = 0; lane < WARP_SIZE; lane++)
+                ibuf[nxt][lane] = ibuf[cur][lane] + ibuf[cur][lane ^ off];
+            cur = nxt;
+        }
+        *s = ibuf[cur][0];
+    } else {
+        *s = warp_sums[0];
+    }
+}

+        for (int w = 1; w < nwarps; w++)
+            tmp[lane] += tmp[w * warp_sz + lane];
+    float buf[2][32];
+    memcpy(buf[0], tmp, warp_sz * sizeof(float));
+    int cur = 0;
+    for (int offset = warp_sz / 2; offset > 0; offset >>= 1) {
+        int nxt = 1 - cur;
+        for (int lane = 0; lane < warp_sz; lane++)
+            buf[nxt][lane] = buf[cur][lane] + buf[cur][lane ^ offset];
+        cur = nxt;
+    }
+    *s = buf[cur][0];
+}
+
+// Q8_0 x Q8_1 deterministic dot product — matches GPU mmvq kernel
+// GPU: nwarps=4, 128 threads, qi=8, vdr=2, 4 threads per block (each handles 8 bytes)
+void ggml_vec_dot_q8_0_q8_1_det(int n, float * GGML_RESTRICT s, size_t bs, const void * GGML_RESTRICT vx, size_t bx, const void * GGML_RESTRICT vy, size_t by, int nrc) {
+    assert(n % QK8_0 == 0);
+    assert(nrc == 1);
+    UNUSED(nrc); UNUSED(bx); UNUSED(by); UNUSED(bs);
+
+    const block_q8_0 * GGML_RESTRICT x = vx;
+    const block_q8_1 * GGML_RESTRICT y = vy;
+    const int nb = n / QK8_0;
+
+    const int nwarps = 4, warp_sz = 32, nthreads = nwarps * warp_sz; // 128
+    const int qi = 8, vdr = 2;
+    const int threads_per_block = qi / vdr; // 4
+    const int blocks_per_iter = vdr * nthreads / qi; // 32
+
+    float tmp[128];
+    for (int tid = 0; tid < nthreads; tid++) {
+        float acc = 0.0f;
+        int kqs = vdr * (tid % threads_per_block); // 0,2,4,6
+        for (int kbx = tid / threads_per_block; kbx < nb; kbx += blocks_per_iter) {
+            // Each thread handles vdr=2 int32 words starting at kqs
+            // dp4a: 4 int8 products per word
+            int sumi = 0;
+            for (int i = 0; i < vdr; i++) {
+                int byte_off = (kqs + i) * 4; // 4 bytes per int32
+                for (int b = 0; b < 4; b++)
+                    sumi += (int)x[kbx].qs[byte_off + b] * (int)y[kbx].qs[byte_off + b];
+            }
+            float d0 = GGML_CPU_FP16_TO_FP32(x[kbx].d);
+            float d1 = GGML_CPU_FP16_TO_FP32(y[kbx].d);
+            acc += d0 * d1 * (float)sumi;
+        }
+        tmp[tid] = acc;
+    }
+
+    // Inter-warp: warp 1+ store to shared, warp 0 collects
+    for (int w = 1; w < nwarps; w++)
+        for (int lane = 0; lane < warp_sz; lane++)
+            tmp[lane] += tmp[w * warp_sz + lane];
+
+    // Warp 0 butterfly reduction
+    float buf[2][32];
+    memcpy(buf[0], tmp, warp_sz * sizeof(float));
+    int cur = 0;
+    for (int off = 16; off > 0; off >>= 1) {
+        int nxt = 1 - cur;
+        for (int lane = 0; lane < warp_sz; lane++)
+            buf[nxt][lane] = buf[cur][lane] + buf[cur][lane ^ off];
+        cur = nxt;
+    }
+    *s = buf[cur][0];
+}
+
+// IQ4_NL x Q8_1 deterministic dot product — matches GPU vec_dot_iq4_nl_q8_1
+void ggml_vec_dot_iq4_nl_q8_1_det(int n, float * GGML_RESTRICT s, size_t bs, const void * GGML_RESTRICT vx, size_t bx, const void * GGML_RESTRICT vy, size_t by, int nrc) {
+    assert(n % QK4_NL == 0);
+    assert(nrc == 1);
+    UNUSED(nrc); UNUSED(bx); UNUSED(by); UNUSED(bs);
+
+    const block_iq4_nl * GGML_RESTRICT x = vx;
+    const block_q8_1   * GGML_RESTRICT y = vy;
+    const int nb = n / QK4_NL;
+
+    const int nthreads = 32;
+    float thread_acc[32];
+    for (int tid = 0; tid < nthreads; tid++) {
+        float acc = 0.0f;
+        for (int kbx = tid; kbx < nb; kbx += nthreads) {
+            int sumi = 0;
+            for (int j = 0; j < QK4_NL/2; j++) {
+                const uint8_t q = x[kbx].qs[j];
+                sumi += kvalues_iq4nl[q & 0xF] * (int)y[kbx].qs[2*j];
+                sumi += kvalues_iq4nl[q >> 4]  * (int)y[kbx].qs[2*j+1];
+            }
+            float d = GGML_CPU_FP16_TO_FP32(x[kbx].d) * GGML_CPU_FP16_TO_FP32(y[kbx].d);
+            acc += d * (float)sumi;
+        }
+        thread_acc[tid] = acc;
+    }
+    float buf[2][32];
+    memcpy(buf[0], thread_acc, 32 * sizeof(float));
+    int cur = 0;
+    for (int off = 16; off > 0; off >>= 1) {
+        int nxt = 1 - cur;
+        for (int lane = 0; lane < 32; lane++)
+            buf[nxt][lane] = buf[cur][lane] + buf[cur][lane ^ off];
+        cur = nxt;
+    }
+    *s = buf[cur][0];
+}
+
+// CPU emulation of get_int_from_table_16: takes int32 of 8 packed nibbles,
+// looks up each nibble in table, returns {even_bytes, odd_bytes} as two int32
+static void cpu_get_int_from_table_16(uint32_t q4, const int8_t * table, int32_t * out_x, int32_t * out_y) {
+    // q4 contains 8 nibbles (4 bits each)
+    // GPU splits into even-indexed bytes (v.x) and odd-indexed bytes (v.y)
+    int8_t vals[8];
+    for (int i = 0; i < 8; i++)
+        vals[i] = table[(q4 >> (4*i)) & 0xF];
+    // v.x = bytes 0,2,4,6 (even); v.y = bytes 1,3,5,7 (odd)
+    uint8_t xb[4] = { (uint8_t)vals[0], (uint8_t)vals[2], (uint8_t)vals[4], (uint8_t)vals[6] };
+    uint8_t yb[4] = { (uint8_t)vals[1], (uint8_t)vals[3], (uint8_t)vals[5], (uint8_t)vals[7] };
+    memcpy(out_x, xb, 4);
+    memcpy(out_y, yb, 4);
+}
+
+// CPU dp4a: dot product of 4 signed int8 values packed in int32
+static int32_t cpu_dp4a(int32_t a, int32_t b, int32_t c) {
+    const int8_t * va = (const int8_t *)&a;
+    const int8_t * vb = (const int8_t *)&b;
+    return c + (int)va[0]*vb[0] + (int)va[1]*vb[1] + (int)va[2]*vb[2] + (int)va[3]*vb[3];
+}
+
+// IQ4_XS x Q8_1 deterministic dot product — matches GPU vec_dot_iq4_xs_q8_1
+// GPU: qi=32, vdr=4, iqs = 4*(tid%8) → {0,4,8,12,16,20,24,28}
+// kbx = tid/8, increments by blocks_per_iter
+void ggml_vec_dot_iq4_xs_q8_1_det(int n, float * GGML_RESTRICT s, size_t bs, const void * GGML_RESTRICT vx, size_t bx, const void * GGML_RESTRICT vy, size_t by, int nrc) {
+    assert(n % QK_K == 0);
+    assert(nrc == 1);
+    UNUSED(nrc); UNUSED(bx); UNUSED(by); UNUSED(bs);
+
+    const block_iq4_xs * GGML_RESTRICT x = vx;
+    const block_q8_1   * GGML_RESTRICT y = vy;
+    const int nb = n / QK_K;
+
+    // GPU has nwarps * warp_size threads. For IQ4_XS:
+    // qi/vdr = 32/4 = 8 threads per super-block
+    // blocks_per_iter = vdr * nwarps * 32 / qi = 4 * nwarps
+    // We simulate with a fixed thread count matching the GPU
+    const int nwarps = 4, warp_sz = 32;
+    const int nthreads = nwarps * warp_sz;  // 128
+    const int qi_over_vdr = 8;  // qi/vdr = 32/4
+    const int blocks_per_iter = 4 * nwarps;  // 16
+
+    float thread_acc[128];
+    for (int tid = 0; tid < nthreads; tid++) {
+        float acc = 0.0f;
+        const int iqs = 4 * (tid % qi_over_vdr);  // 0,4,8,12,16,20,24,28
+
+        for (int kbx = tid / qi_over_vdr; kbx < nb; kbx += blocks_per_iter) {
+            const int kby = kbx * (QK_K / QK8_1);  // kbx * 8
+
+            int sumi = 0;
+            for (int j = 0; j < 4; j++) {
+                // get_int_b4(bq4->qs, iqs + j) reads int32 word at index (iqs+j)
+                // Each int32 word contains 8 nibbles = 8 IQ4 values
+                uint32_t aux_q4;
+                memcpy(&aux_q4, &x[kbx].qs[(iqs + j) * 4], 4);
+
+                // Table lookup: convert 8 nibbles to 8 int8 values via kvalues_iq4nl
+                int32_t vx_val, vy_val;
+                cpu_get_int_from_table_16(aux_q4, kvalues_iq4nl, &vx_val, &vy_val);
+
+                // Q8_1 block: bq8_1[iqs/4]
+                const block_q8_1 * yb = &y[kby + iqs/4];
+                int32_t u0, u1;
+                memcpy(&u0, &yb->qs[(j + 0) * 4], 4);  // get_int_b4(qs, j)
+                memcpy(&u1, &yb->qs[(j + 4) * 4], 4);  // get_int_b4(qs, j+4)
+
+                sumi = cpu_dp4a(vx_val, u0, sumi);
+                sumi = cpu_dp4a(vy_val, u1, sumi);
+            }
+
+            // Scale: 6-bit per sub-block
+            int ls = ((x[kbx].scales_l[iqs/8] >> (iqs & 0x04)) & 0x0F)
+                   | (((x[kbx].scales_h >> (iqs/2)) & 0x03) << 4);
+            sumi *= (ls - 32);
+
+            float d = GGML_CPU_FP16_TO_FP32(x[kbx].d) * GGML_CPU_FP16_TO_FP32(y[kby + iqs/4].d);
+            acc += d * (float)sumi;
+        }
+        thread_acc[tid] = acc;
+    }
+    // GPU reduction: warp 0 sequentially adds other warps' values, then butterfly
+    // 1. Each warp stores its per-lane values (already in thread_acc)
+    // 2. Warp 0 (lanes 0-31) adds warps 1,2,3 same-lane values sequentially
+    for (int lane = 0; lane < warp_sz; lane++)
+        for (int w = 1; w < nwarps; w++)
+            thread_acc[lane] += thread_acc[w * warp_sz + lane];
+    // 3. Butterfly within warp 0
+    float buf[2][32];
+    memcpy(buf[0], thread_acc, warp_sz * sizeof(float));
+    int cur = 0;
+    for (int off = warp_sz/2; off > 0; off >>= 1) {
+        int nxt = 1 - cur;
+        for (int lane = 0; lane < warp_sz; lane++)
+            buf[nxt][lane] = buf[cur][lane] + buf[cur][lane ^ off];
+        cur = nxt;
+    }
+    *s = buf[cur][0];
+}
+
+// Q5_K x Q8_1 deterministic dot product — matches GPU vec_dot_q5_K_q8_1
+// GPU: qi=32, vdr=2, iqs = 2*(tid%16) → {0,2,4,...,30}
+// kbx = tid/16, blocks_per_iter = 2*nwarps = 8
+void ggml_vec_dot_q5_K_q8_1_det(int n, float * GGML_RESTRICT s, size_t bs, const void * GGML_RESTRICT vx, size_t bx, const void * GGML_RESTRICT vy, size_t by, int nrc) {
+    assert(n % QK_K == 0);
+    assert(nrc == 1);
+    UNUSED(nrc); UNUSED(bx); UNUSED(by); UNUSED(bs);
+
+    const block_q5_K * GGML_RESTRICT x = vx;
+    const block_q8_1 * GGML_RESTRICT y = vy;
+    const int nb = n / QK_K;
+
+    const int nwarps = 4, warp_sz = 32;
+    const int nthreads = nwarps * warp_sz;  // 128
+    const int qi_over_vdr = 16;  // qi/vdr = 32/2
+    const int blocks_per_iter = 2 * nwarps;  // vdr * nwarps = 8
+
+    float thread_acc[128];
+    for (int tid = 0; tid < nthreads; tid++) {
+        float acc = 0.0f;
+        const int iqs = 2 * (tid % qi_over_vdr);  // 0,2,4,...,30
+
+        for (int kbx = tid / qi_over_vdr; kbx < nb; kbx += blocks_per_iter) {
+            const int kby = kbx * (QK_K / QK8_1);  // kbx * 8
+
+            // bq8_offset: which pair of Q8_1 blocks (0,2,4,6)
+            const int bq8_offset = 2 * ((iqs/2) / 4);
+
+            // Read vl[2]: two int32 words from qs
+            const int * ql = (const int *)(x[kbx].qs + 16 * bq8_offset + 4 * ((iqs/2)%4));
+            int32_t vl0 = ql[0];
+            int32_t vl1 = ql[4];
+
+            // Read vh[2]: two int32 words from qh, shifted by bq8_offset
+            const int * qh = (const int *)(x[kbx].qh + 4 * ((iqs/2)%4));
+            int32_t vh0 = qh[0] >> bq8_offset;
+            int32_t vh1 = qh[4] >> bq8_offset;
+
+            // Decode scales
+            const uint16_t * scales = (const uint16_t *)x[kbx].scales;
+            uint16_t aux[2];
+            const int j = bq8_offset/2;
+            if (j < 2) {
+                aux[0] = scales[j+0] & 0x3f3f;
+                aux[1] = scales[j+2] & 0x3f3f;
+            } else {
+                aux[0] = ((scales[j+2] >> 0) & 0x0f0f) | ((scales[j-2] & 0xc0c0) >> 2);
+                aux[1] = ((scales[j+2] >> 4) & 0x0f0f) | ((scales[j-0] & 0xc0c0) >> 2);
+            }
+            const uint8_t * sc = (const uint8_t *)aux;
+            const uint8_t * m  = sc + 2;
+
+            // Read Q8_1 data and compute dot products
+            int32_t u[4];  // 2*QR5_K
+            float d8[2];   // QR5_K
+            for (int i = 0; i < 2; i++) {  // QR5_K = 2
+                const block_q8_1 * bq8i = &y[kby + bq8_offset + i];
+                d8[i] = GGML_CPU_FP16_TO_FP32(bq8i->d);
+                const int * q8 = (const int *)bq8i->qs + ((iqs/2)%4);
+                u[2*i+0] = q8[0];
+                u[2*i+1] = q8[4];
+            }
+
+            // impl_vmmq: compute dot products using dp4a
+            float sumf_d = 0.0f, sumf_m = 0.0f;
+            for (int i = 0; i < 2; i++) {
+                // Extract low 4 bits, shifted by 4*i
+                int32_t vl0i = (vl0 >> (4*i)) & 0x0F0F0F0F;
+                int32_t vl1i = (vl1 >> (4*i)) & 0x0F0F0F0F;
+                // Extract high bit, shifted
+                int32_t vh0i = ((vh0 >> i) << 4) & 0x10101010;
+                int32_t vh1i = ((vh1 >> i) << 4) & 0x10101010;
+                // Combine to 5-bit values
+                int32_t v0i = vl0i | vh0i;
+                int32_t v1i = vl1i | vh1i;
+                // dp4a: dot product of 4 int8 pairs
+                int dot1 = cpu_dp4a(v1i, u[2*i+1], cpu_dp4a(v0i, u[2*i+0], 0));
+                int dot2 = cpu_dp4a(0x01010101, u[2*i+1], cpu_dp4a(0x01010101, u[2*i+0], 0));
+
+                sumf_d += d8[i] * (float)(dot1 * sc[i]);
+                sumf_m += d8[i] * (float)(dot2 * m[i]);
+            }
+
+            float dm_d = GGML_CPU_FP16_TO_FP32(x[kbx].d);
+            float dm_m = GGML_CPU_FP16_TO_FP32(x[kbx].dmin);
+            // Match GPU: fmaf(dm_d, sumf_d, -(dm_m * sumf_m))
+            float t = dm_m * sumf_m;
+            acc += fmaf(dm_d, sumf_d, -t);
+        }
+        thread_acc[tid] = acc;
+    }
+    // GPU reduction: warp 0 sequentially adds other warps' values, then butterfly
+    for (int lane = 0; lane < warp_sz; lane++)
+        for (int w = 1; w < nwarps; w++)
+            thread_acc[lane] += thread_acc[w * warp_sz + lane];
+    float buf[2][32];
+    memcpy(buf[0], thread_acc, warp_sz * sizeof(float));
+    int cur = 0;
+    for (int off = warp_sz/2; off > 0; off >>= 1) {
+        int nxt = 1 - cur;
+        for (int lane = 0; lane < warp_sz; lane++)
+            buf[nxt][lane] = buf[cur][lane] + buf[cur][lane ^ off];
+        cur = nxt;
+    }
+    *s = buf[cur][0];
+}

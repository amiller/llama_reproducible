+    const float dm4f_x = GGML_CPU_FP16_TO_FP32(bq4->d);
+    const float dm4f_y = GGML_CPU_FP16_TO_FP32(bq4->dmin);
+    // GPU: NVCC inlines and may auto-contract this expression
+    return fmaf(dm4f_x, sumf_d, -(dm4f_y * sumf_m));

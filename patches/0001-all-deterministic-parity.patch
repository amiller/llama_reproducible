+// Q8_1 quantization matching GPU quantize_mmq_q8_1_cuda formula.
+// GPU mmq uses: d_inv = 127/amax, q = roundf(xi * d_inv), d = 1/d_inv
+// This differs from standard Q8_1: d = amax/127, q = roundf(xi/d)
+void quantize_row_q8_1_mmq(const float * GGML_RESTRICT x, void * GGML_RESTRICT vy, int64_t k) {
+    assert(QK8_1 == 32);
+    assert(k % QK8_1 == 0);
+    block_q8_1 * y = vy;
+    const int nb = k / QK8_1;
+
+    for (int i = 0; i < nb; i++) {
+        float amax = 0.0f;
+        for (int j = 0; j < QK8_1; j++)
+            amax = MAX(amax, fabsf(x[i*QK8_1 + j]));
+
+        const float d_inv = 127.0f / amax;
+        const float d = amax == 0.0f ? 0.0f : 1.0f / d_inv;
+        y[i].d = GGML_FP32_TO_FP16(d);
+
+        float sum = 0.0f;
+        for (int j = 0; j < QK8_1; j++) {
+            const float xi = x[i*QK8_1 + j];
+            const int8_t q = amax == 0.0f ? 0 : (int8_t)roundf(xi * d_inv);
+            y[i].qs[j] = q;
+            sum += xi;
+        }
+        // GPU mmq stores raw sum (NOT sum*d) in ds4.y:
+        //   ds4[iqs/32] = make_half2(d, sum)
+        y[i].s = GGML_FP32_TO_FP16(sum);
+    }
+}

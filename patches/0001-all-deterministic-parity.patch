+    const int64_t i02 = batch % ne02;
+
+    const float * A_batch = A + i02 * nb02 + i03 * nb03;
+    const float * B_batch = B + i02 * nb12 + i03 * nb13;
+    float * X_batch = X + i02 * nb2 + i03 * nb3;

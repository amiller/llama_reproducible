+#!/bin/bash
+# Deterministic Seed Verifier
+#
+# Given a GGUF model, seed, prompt, and expected output — verify that
+# CPU inference produces the exact same tokens as GPU.
+#
+# This proves a specific (model, seed, prompt) → output mapping is genuine,
+# not cherry-picked or edited. Anyone with the model file can verify.
+#
+# Usage:
+#   ./verify.sh <model.gguf> <seed> <temp> "<prompt>" "<expected_output>"
+#
+# Docker usage (no build needed):
+#   docker run --rm -v /path/to/models:/models det-verify \
+#     -m /models/model.gguf -p "prompt" -n 30 --seed 42 --temp 0.7 --deterministic
+
+set -euo pipefail
+
+MODEL="${1:?Usage: $0 <model.gguf> <seed> <temp> \"prompt\" \"expected_output\"}"
+SEED="${2:?}"
+TEMP="${3:?}"
+PROMPT="${4:?}"
+EXPECTED="${5:?}"
+
+SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
+REPO_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
+
+# Build if needed
+if [ ! -f "$REPO_DIR/build-verify/bin/llama-det-diag" ]; then
+    echo "Building CPU deterministic verifier..."
+    cmake -B "$REPO_DIR/build-verify" -S "$REPO_DIR" \
+      -DGGML_CUDA=OFF -DGGML_DETERMINISTIC=OFF \
+      -DGGML_CPU_REPACK=OFF -DGGML_LLAMAFILE=OFF \
+      -DGGML_NATIVE=OFF -DGGML_AVX2=OFF -DGGML_AVX=OFF \
+      -DGGML_FMA=OFF -DGGML_F16C=OFF \
+      -DCMAKE_C_FLAGS="-mfma" -DCMAKE_CXX_FLAGS="-mfma" \
+      > /dev/null 2>&1
+    cmake --build "$REPO_DIR/build-verify" --target llama-det-diag -j$(nproc) > /dev/null 2>&1
+fi
+
+DIAG="$REPO_DIR/build-verify/bin/llama-det-diag"
+
+# Count tokens in expected output (rough: split by spaces)
+N_TOKENS=$(echo "$EXPECTED" | wc -w)
+N_TOKENS=$((N_TOKENS + 5))  # pad for tokenization differences
+
+echo "=== Deterministic Seed Verification ==="
+echo "Model:    $(basename "$MODEL")"
+echo "Seed:     $SEED"
+echo "Temp:     $TEMP"
+echo "Prompt:   \"$PROMPT\""
+echo "Expected: \"$EXPECTED\""
+echo ""
+
+# Run
+ACTUAL=$("$DIAG" -m "$MODEL" -p "$PROMPT" -n "$N_TOKENS" \
+  --seed "$SEED" --temp "$TEMP" --deterministic \
+  2>/tmp/verify_tokens.txt > /dev/null && \
+  grep "^Token" /tmp/verify_tokens.txt | \
+  sed "s/Token [0-9]*: id=[0-9]* '//" | sed "s/'$//" | tr -d '\n')
+
+echo "Got:      \"$ACTUAL\""
+echo ""
+
+if echo "$ACTUAL" | grep -qF "$EXPECTED"; then
+    echo "✓ VERIFIED — CPU output matches expected text"
+    exit 0
+else
+    echo "✗ MISMATCH — output differs from expected"
+    exit 1
+fi

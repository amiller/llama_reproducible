+build-det-real/bin/llama-det-diag -m model.gguf -p "test" -n 3 -ngl 99 --deterministic > gpu.txt
+build-det-cpu/bin/llama-det-diag  -m model.gguf -p "test" -n 3 -ngl 0  --deterministic > cpu.txt
+diff gpu.txt cpu.txt
+
+# Benchmark deterministic overhead
+./benchmarks/deterministic-bench.sh -m model.gguf
+```

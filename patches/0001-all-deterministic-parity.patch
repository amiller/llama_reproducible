+// Compute one Q6_K thread's partial dot product for a single block
+static inline float q6k_partial(const block_q6_K * bq6, const block_q8_1 * bq8, int iqs, float * d6_out) {
+    const float d6 = GGML_CPU_FP16_TO_FP32(bq6->d);
+    const int bq8_offset = 2 * 2 * (iqs / 16) + (iqs % 16) / 8;
+    const int scale_offset = 8 * (iqs / 16) + (iqs % 16) / 4;
+    const int vh_shift = 2 * ((iqs % 16) / 8);
+
+    int vl;
+    memcpy(&vl, &bq6->ql[iqs * 4], sizeof(int));
+
+    int vh;
+    const int qh_idx = 8 * (iqs / 16) + iqs % 8;
+    memcpy(&vh, &bq6->qh[qh_idx * 4], sizeof(int));
+    vh >>= vh_shift;
+
+    const int8_t *scales = bq6->scales + scale_offset;
+
+    int u[2];
+    float d8[2];
+    for (int qi = 0; qi < 2; ++qi) {
+        const block_q8_1 *bq8i = &bq8[bq8_offset + 2 * qi];
+        memcpy(&u[qi], &bq8i->qs[(iqs % 8) * 4], sizeof(int));
+        d8[qi] = GGML_CPU_FP16_TO_FP32(bq8i->d);
+    }
+
+    float partial = 0.0f;
+    for (int qi = 0; qi < 2; ++qi) {
+        const int sc = scales[4 * qi];
+        const int vil = (vl >> (4 * qi)) & 0x0F0F0F0F;
+        const int vih = ((vh >> (4 * qi)) << 4) & 0x30303030;
+        int vi_packed = (vil | vih);
+        int8_t vi_bytes[4], packed_bytes[4];
+        memcpy(packed_bytes, &vi_packed, 4);
+        for (int b = 0; b < 4; b++)
+            vi_bytes[b] = packed_bytes[b] - 0x20;
+        int vi;
+        memcpy(&vi, vi_bytes, 4);
+        partial = fmaf(d8[qi], (float)(dp4a_cpu(vi, u[qi], 0) * sc), partial);
+    }

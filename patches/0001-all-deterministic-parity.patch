+        int cur = 0;
+        for (int off = WARP_SIZE/2; off > 0; off >>= 1) {
+            int nxt = 1 - cur;
+            for (int lane = 0; lane < WARP_SIZE; lane++)
+                buf[nxt][lane] = buf[cur][lane] + buf[cur][lane ^ off];
+            cur = nxt;
+        }
+        warp_sums[w] = buf[cur][0];
+    }
+
+    // Phase 3: inter-warp reduction (warp 0 accumulates, then butterfly)
+    if (nwarps > 1) {
+        float iw = warp_sums[0];
+        for (int w = 1; w < nwarps; w++) iw += warp_sums[w];
